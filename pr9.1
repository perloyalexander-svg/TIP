#include <iostream>
using namespace std;

double divide(int a, int b) {
    if (b == 0) {
        throw invalid_argument("Division by zero");
    }
    return (double)a / b;
}

int main() {
    int a, b;

    while (true) {
        cout << "Enter number: ";
        cin >> a;
        cout << "Enter number: ";
        cin >> b;

        try {
            double result = divide(a, b);
            cout << "Result: " << result << endl;
            break;
        }
        catch (invalid_argument& e) {
            cout << e.what() << endl;
        }
        catch (...) {
            cout << "Unknown error" << endl;
        }
    }

    return 0;
}
